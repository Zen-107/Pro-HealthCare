# =============================================================
#  ตัวอย่างค่าสภาพแวดล้อม — คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่า
#  cp .env.example .env      (หรือ copy ด้วยมือบน Windows)
# =============================================================

# ---- MySQL (Docker) ----
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=prohealthcare
MYSQL_USER=prohealth
MYSQL_PASSWORD=prohealthpass
MYSQL_PORT=3306
ADMINER_PORT=8080

# ---- Backend (FastAPI) ----
# DATABASE_URL ใช้ค่าจากด้านบน: mysql+pymysql://USER:PASSWORD@host.docker.internal:PORT/DB
DATABASE_URL=mysql+pymysql://prohealth:prohealthpass@127.0.0.1:3306/prohealthcare
SECRET_KEY=เปลี่ยนเป็นคีย์ยาวๆสุ่ม-ใช้-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ---- Frontend (React) ----
VITE_API_BASE_URL=http://localhost:8000
